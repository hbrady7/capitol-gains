# ── Database: Neon serverless Postgres ────────────────────────────────────────
# Get this from the Neon dashboard (or `vercel env pull` once the integration is
# added). Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── Decision brain: Anthropic API (Phase 5) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Congress data source (also configurable in the Settings page) ─────────────
# provider options: seed | house-stock-watcher | senate-stock-watcher | finnhub
# `seed` works offline with zero setup. Switch to a live source when ready.
CONGRESS_SOURCE=seed
CONGRESS_SOURCE_URL=
CONGRESS_API_KEY=

# ── SEC EDGAR (Form 4 insider buys, Phase 3) ──────────────────────────────────
# EDGAR requires a descriptive User-Agent identifying you, and ~10 req/s fair use.
SEC_USER_AGENT=capitol-gains hollisbrady2004@gmail.com

# ── Quotes for suggested limit prices (last close). Synthetic fallback if down. ─
QUOTE_SOURCE_URL=https://stooq.com/q/l/?s={SYMBOL}.us&f=sd2t2ohlcv&h&e=csv

# ── Cron / HTTP trigger protection (Phase 7) ──────────────────────────────────
CRON_SECRET=

# ── Live broker creds (Phase 6, only needed when paper_mode is off) ───────────
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
