# Local SQLite file — no external database.
DATABASE_URL=file:./data/local.db

# Congress data source (also configurable in the Settings page).
# provider options: seed | house-stock-watcher | senate-stock-watcher | finnhub
# `seed` works offline with zero setup. Switch to a live source when ready.
CONGRESS_SOURCE=seed
# Override the dataset/API URL if a default endpoint moves (optional).
CONGRESS_SOURCE_URL=
# Some sources (e.g. Finnhub) require an API key.
CONGRESS_API_KEY=

# Quote source for suggested limit prices (last close). Falls back to a
# deterministic synthetic price when unreachable so the app never breaks.
QUOTE_SOURCE_URL=https://stooq.com/q/l/?s={SYMBOL}.us&f=sd2t2ohlcv&h&e=csv
